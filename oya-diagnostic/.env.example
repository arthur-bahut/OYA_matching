# Airtable — créer un Personal Access Token sur https://airtable.com/create/tokens
# Scopes requis : data.records:write  |  Accès : la base concernée
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# ID de la base Airtable (visible dans l'URL : airtable.com/appXXXX/...)
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Nom exact de la table dans Airtable
VITE_AIRTABLE_TABLE=XXXXXXXXXX
